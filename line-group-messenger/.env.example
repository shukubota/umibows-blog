# LINE group messenger 設定
# このファイルを `.env` にコピーして、実際の値を入れる:
#   cp .env.example .env
# `.env` は .gitignore で除外されているのでコミットされない。

# LINE Messaging API の長期チャネルアクセストークン
# 取得: LINE Developers Console > 該当チャネル > Messaging API設定 > チャネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=replace_with_your_token

# 送信先グループID（C で始まる文字列）
# 取得方法: SKILL.md の groupId 取得手順を参照
LINE_TARGET_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxx
