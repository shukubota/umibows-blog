# LINE group messenger 設定
# このファイルを `.env` にコピーして、実際の値を入れる:
#   cp .env.example .env
# `.env` は .gitignore で除外されているのでコミットされない。

# LINE Messaging API の長期チャネルアクセストークン
# 取得: LINE Developers Console > 該当チャネル > Messaging API設定 > チャネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=replace_with_your_token

# 送信先グループID（C で始まる文字列）
# 取得方法: SKILL.md の groupId 取得手順を参照
LINE_TARGET_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ローカル画像送信（オプション）---
# GCSバケット名（画像の一時アップロード先）
GCS_BUCKET_NAME=your-bucket-name

# GCPプロジェクトID（未設定時はADCのデフォルトプロジェクトを使用）
GCS_PROJECT_ID=your-gcp-project-id

# 署名付きURL生成に使うサービスアカウントのメールアドレス
# 事前に: gcloud auth application-default login
# 自分のアカウントに roles/iam.serviceAccountTokenCreator を付与しておくこと
GCS_SERVICE_ACCOUNT_EMAIL=line-messenger@your-project.iam.gserviceaccount.com
