{
  "name": "mahjong-nanikiru",
  "version": "0.4.0",
  "private": true,
  "description": "ui:// で麻雀の手牌(何切る)を描画する MCP Apps サンプルサーバー（公式SDK準拠）",
  "type": "module",
  "scripts": {
    "build:view": "vite build",
    "build:server": "esbuild index.ts server.ts --outdir=dist --platform=node --format=esm",
    "build": "npm run build:view && npm run build:server",
    "dev": "tsx index.ts",
    "start": "node dist/index.js",
    "smoke": "node dist/index.js < smoke.jsonl"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
