{
  "name": "umibows-blog-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "umibows-blog の海スポットを地図UI付き(ui://)で返す MCP Apps サーバー例",
  "type": "module",
  "bin": {
    "umibows-blog-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "smoke:dev": "tsx src/index.ts < smoke.jsonl",
    "build": "tsc && mkdir -p dist/data dist/ui && cp src/data/spots.json dist/data/ && cp src/ui/spot-map.html dist/ui/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
