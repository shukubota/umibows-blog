{
  "name": "stock-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing Yahoo Finance stock data to Claude (US stocks focus)",
  "type": "module",
  "bin": {
    "stock-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
