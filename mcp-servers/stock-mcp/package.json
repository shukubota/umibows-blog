  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "yahoo-finance2": "^3.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
